{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ApplauseLab/bachkator/docs/schemas/provider-session.schema.json",
  "title": "Bachkator Provider Session Evidence",
  "type": "object",
  "required": [
    "schema",
    "provider",
    "session_id",
    "target",
    "attempt",
    "workspace",
    "workspace_dirty",
    "events_path",
    "executed_command",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "bach.provider_session.v1" },
    "provider": { "const": "opencode" },
    "session_id": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "attempt": { "type": "integer", "minimum": 1 },
    "workspace": { "type": "string", "minLength": 1 },
    "workspace_dirty": { "type": "boolean" },
    "events_path": { "type": "string", "minLength": 1 },
    "executed_command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
