{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bachkator.dev/schemas/backend-factory-work-item-v1.schema.json",
  "title": "Bach Backend Factory Work Item v1",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "factory",
    "workflow",
    "lifecycle",
    "current_phase",
    "title",
    "priority",
    "source_type",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "bach.backend.factory_work_item.v1" },
    "id": { "type": "string", "minLength": 1 },
    "factory": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "lifecycle": { "enum": ["pending", "claimed", "running", "waiting_approval", "completed", "failed", "cancelled"] },
    "current_phase": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "body": { "type": "string" },
    "body_hash": { "type": "string" },
    "priority": { "type": "string", "minLength": 1 },
    "labels": { "type": "array", "items": { "type": "string" } },
    "source_type": { "type": "string", "minLength": 1 },
    "dedupe_key": { "type": "string" },
    "submitted_plan_path": { "type": "string" },
    "submitted_plan_hash": { "type": "string" },
    "intake_evidence_id": { "type": "string" },
    "intake_evidence_uri": { "type": "string" },
    "intake_evidence_hash": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "cancelled_at": { "type": "string", "format": "date-time" },
    "cancel_reason": { "type": "string" },
    "claimed_by_daemon_id": { "type": "string" },
    "claimed_at": { "type": "string", "format": "date-time" },
    "claim_expires_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "failed_at": { "type": "string", "format": "date-time" },
    "failure_phase": { "type": "string" },
    "failure_message": { "type": "string" },
    "attempts": {
      "type": "array",
      "items": { "$ref": "#/$defs/attempt" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "attempt": {
      "type": "object",
      "required": [
        "id",
        "work_item_id",
        "attempt_number",
        "status",
        "start_phase",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "work_item_id": { "type": "string", "minLength": 1 },
        "attempt_number": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "minLength": 1 },
        "start_phase": { "type": "string", "minLength": 1 },
        "submitted_plan_path": { "type": "string" },
        "submitted_plan_hash": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["id", "work_item_id", "type", "created_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "work_item_id": { "type": "string", "minLength": 1 },
        "attempt_id": { "type": "string" },
        "type": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "metadata": { "type": "object", "additionalProperties": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
