{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bachkator.dev/schemas/backend-plan-ledger-v1.schema.json",
  "title": "Bach Backend Plan Ledger v1",
  "type": "object",
  "required": ["schema_version", "ledger_id", "plan_id", "status", "hash", "recorded_at"],
  "properties": {
    "schema_version": { "const": "bach.plan_ledger.v1" },
    "ledger_id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pending", "in_progress", "implemented", "failed"] },
    "hash": { "type": "string", "pattern": "^sha256:" },
    "run_id": { "type": "string" },
    "commit": { "type": "string" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "implemented_at": { "type": "string", "format": "date-time" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "hash": { "type": "string" },
        "content": { "type": "object" },
        "metadata": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
