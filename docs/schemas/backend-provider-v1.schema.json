{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bachkator.dev/schemas/backend-provider-v1.schema.json",
  "title": "Bach Backend Provider v1",
  "type": "object",
  "required": ["protocol", "provider", "version", "capabilities"],
  "properties": {
    "protocol": { "const": "bach.backend.v1" },
    "provider": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "runs",
          "evidence_refs",
          "quality_reports",
          "findings",
          "factory_queue",
          "plan_ledger",
          "approvals"
        ]
      },
      "uniqueItems": true
    },
    "limits": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "additionalProperties": false
}
