#!/bin/sh
set -eu

message_file="${1:-}"

if [ -z "$message_file" ] || [ ! -f "$message_file" ]; then
  printf '%s\n' "commit-msg hook expected a commit message file path" >&2
  exit 1
fi

IFS= read -r subject < "$message_file" || subject=""

case "$subject" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9._/-]*\))?!?: .+'

if printf '%s\n' "$subject" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
Commit message must use a semantic subject line.

Expected:
  type(scope): subject
  type: subject

Allowed types:
  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert

Examples:
  feat(cli): add dry-run output
  docs: update agent workflow
EOF

exit 1
